<?xml version="1.0" encoding="utf-8"?>
<!-- QuickLook reads this at install time. <Version> must be present and
     non-empty or install fails with "Invalid plugin, version not defined".
     Package.ps1 / CI overwrites <Version> from the release tag at pack time;
     the value here is the local/dev default. -->
<Metadata>
  <Namespace>QuickLook.Plugin.MIQ</Namespace>
  <Version>0.9.5</Version>
  <Description>Preview medical volume images (NIfTI, FreeSurfer MGH, MRtrix MIF, NRRD) as an interactive 2x2 orthogonal slice grid plus metadata.</Description>
</Metadata>
